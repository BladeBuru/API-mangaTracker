<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{subject}}</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1a1a1a;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f7;padding:24px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.08);">
          <tr>
            <td style="background:#D32F2F;padding:24px 32px;color:#ffffff;font-size:20px;font-weight:600;">
              Manga Tracker
            </td>
          </tr>
          <tr>
            <td style="padding:32px;">
              <h1 style="margin:0 0 16px;font-size:22px;font-weight:600;line-height:1.3;">
                {{#if isFr}}Réinitialisation de votre mot de passe{{else}}Reset your password{{/if}}
              </h1>
              <p style="margin:0 0 24px;font-size:15px;line-height:1.5;color:#444;">
                {{#if isFr}}
                  Bonjour {{username}}, vous avez demandé à réinitialiser votre mot
                  de passe. Cliquez sur le bouton ci-dessous pour définir un nouveau
                  mot de passe. Le lien expire dans <strong>30 minutes</strong> et
                  ne peut être utilisé qu'une seule fois.
                {{else}}
                  Hi {{username}}, you requested a password reset. Click the button
                  below to set a new password. The link expires in <strong>30
                  minutes</strong> and can only be used once.
                {{/if}}
              </p>

              <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  <td style="background:#D32F2F;border-radius:8px;">
                    <a href="{{resetUrl}}" style="display:inline-block;padding:14px 28px;color:#ffffff;font-size:16px;font-weight:600;text-decoration:none;">
                      {{#if isFr}}Réinitialiser mon mot de passe{{else}}Reset my password{{/if}}
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:32px 0 8px;font-size:13px;color:#888;line-height:1.5;">
                {{#if isFr}}
                  Si le bouton ne fonctionne pas, copiez ce lien dans votre navigateur :
                {{else}}
                  If the button doesn't work, copy this link into your browser:
                {{/if}}
              </p>
              <p style="margin:0 0 24px;font-size:12px;color:#666;word-break:break-all;background:#f4f4f7;padding:10px;border-radius:6px;">
                {{resetUrl}}
              </p>

              <hr style="border:none;border-top:1px solid #e5e5e5;margin:24px 0;">

              <p style="margin:0 0 8px;font-size:13px;color:#444;line-height:1.5;">
                <strong>{{#if isFr}}Vous n'avez pas demandé ce reset ?{{else}}You didn't request this?{{/if}}</strong>
              </p>
              <p style="margin:0;font-size:12px;color:#888;line-height:1.5;">
                {{#if isFr}}
                  Ignorez cet email. Votre mot de passe actuel reste valide. Si vous
                  recevez plusieurs demandes de reset que vous n'avez pas initiées,
                  contactez le support — il est possible que quelqu'un essaie d'accéder
                  à votre compte.
                {{else}}
                  Ignore this email. Your current password remains valid. If you
                  receive multiple reset requests you did not initiate, please
                  contact support — someone may be trying to access your account.
                {{/if}}
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding:16px 32px;background:#fafafa;font-size:11px;color:#999;text-align:center;">
              Manga Tracker — bladeburu.com
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
